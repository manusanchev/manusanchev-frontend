---
import NpmIcon from "~/components/shared/icons/NpmIcon.astro";

const {
  url
} = Astro.props;
---

  <a
    href={url}
    class="bg-[#272727] text-sm px-2 py-1 flex items-center gap-x-2 max-w-fit rounded-lg lg:hover:bg-[#303030] lg:transition-colors"
    target="_blank"
  >
    <NpmIcon class="w-4 h-4" />
    npm
  </a>

